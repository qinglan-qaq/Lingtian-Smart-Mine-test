{
  "_comment": "MCP Server 配置 — 可直接粘贴到 Claude Desktop / Cursor 的 mcpServers 配置中",

  "mcpServers": {
    "mining-news": {
      "command": "python",
      "args": ["-m", "mining_news_mcp"],
      "cwd": "./mcp-servers/mining-news-mcp",
      "env": {
        "NEWS_API_KEY": "${NEWS_API_KEY}",
        "PYTHONPATH": "./src",
        "LOG_LEVEL": "INFO"
      }
    },
    "mineral-pdf": {
      "command": "python",
      "args": ["-m", "mineral_pdf_mcp"],
      "cwd": "./mcp-servers/mineral-pdf-mcp",
      "env": {
        "PYTHONPATH": "./src",
        "LOG_LEVEL": "INFO"
      }
    },
    "lme-price": {
      "command": "python",
      "args": ["-m", "lme_price_mcp"],
      "cwd": "./mcp-servers/lme-price-mcp",
      "env": {
        "PYTHONPATH": "./src",
        "LOG_LEVEL": "INFO"
      }
    }
  }
}
