# ============================================================
# Lingtian Smart Mine — 环境变量模板
# 复制为 .env 并填入真实值:  cp .env.example .env
# ============================================================

# ── NewsAPI (mining-news-mcp) ────────────────────────────
# 必需。在 https://newsapi.org/register 注册免费 API Key。
NEWS_API_KEY=your_newsapi_key_here

# ── LLM (Agent) ──────────────────────────────────────────
# 必需。支持 OpenAI 兼容接口 (OpenAI / DeepSeek / 通义千问 等)。
LLM_API_KEY=your_llm_api_key_here
# 可选，默认 gpt-4o
LLM_MODEL=gpt-4o
# 可选，默认 OpenAI；DeepSeek: https://api.deepseek.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# ── LME 价格 (lme-price-mcp / yfinance) ──────────────────
# yfinance 使用 LIT ETF 获取价格，无需额外 API Key。
# 若 yfinance 不可用，自动回退到 PriceSimulator 模拟数据。

# ── PDF 解析 (mineral-pdf-mcp) ───────────────────────────
# 无需额外 API Key。使用 PyMuPDF 本地解析。

# ── 通用 ─────────────────────────────────────────────────
LOG_LEVEL=INFO
