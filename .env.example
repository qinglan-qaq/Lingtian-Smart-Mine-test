# ============================================
# Lingtian Smart Mine — 环境变量模板
# 复制此文件为 .env 并填入真实值
# ============================================

# --- NewsAPI (mining-news-mcp) ---
NEWSAPI_KEY=your_newsapi_key_here

# --- LME Price API (lme-price-mcp) ---
LME_API_KEY=your_lme_api_key_here
LME_API_BASE_URL=https://api.example.com

# --- PDF 解析服务 (mineral-pdf-mcp) ---
PDF_PARSER_API_KEY=your_pdf_parser_api_key_here

# --- LLM (Agent) ---
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4o
LLM_BASE_URL=https://api.openai.com/v1

# --- 通用 ---
LOG_LEVEL=INFO
